ECOFLOW_API_HOST=api-e.ecoflow.com
ECOFLOW_ACCESS_KEY=YOUR_ACCESS_KEY
ECOFLOW_SECRET_KEY=YOUR_SECRET_KEY
ECOFLOW_CLIENT_ID=ecoflow_presence_static
ECOFLOW_KEEPALIVE=30
ECOFLOW_QOS=0
ECOFLOW_QUIET=false
